{
  "name": "@mschreib28/codegraph",
  "version": "0.7.3",
  "description": "Supercharge Claude Code with semantic code intelligence. 94% fewer tool calls • 77% faster exploration • 100% local.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codegraph": "./dist/bin/codegraph.js"
  },
  "files": [
    "dist",
    "public",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "preuninstall": "node dist/bin/uninstall.js",
    "copy-assets": "node scripts/copy-assets.js",
    "dev": "tsc --watch",
    "cli": "npm run build && node dist/bin/codegraph.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest run __tests__/evaluation/",
    "eval": "npm run build && npx tsx __tests__/evaluation/runner.ts",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "code-intelligence",
    "knowledge-graph",
    "static-analysis"
  ],
  "author": "mschreib28",
  "repository": {
    "type": "git",
    "url": "https://github.com/mschreib28/codegraph.git"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.2",
    "node-sqlite3-wasm": "^0.8.30",
    "picomatch": "^4.0.3",
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.25.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.30",
    "@types/picomatch": "^4.0.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "engines": {
    "node": ">=18.0.0 <25.0.0"
  }
}
